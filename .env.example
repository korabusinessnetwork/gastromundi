# ─────────────────────────────────────────────────────────────────────
# GastroMundi / KORA — variáveis de ambiente (exemplo)
#
# Copie para `.env.local` e preencha. NUNCA comitar o `.env.local`.
# Só variáveis com prefixo VITE_ vão pro bundle do front (públicas por
# design). Segredos server-side (ex.: SENTRY_AUTH_TOKEN) NÃO levam VITE_
# e são configurados só no ambiente de build da Vercel.
# ─────────────────────────────────────────────────────────────────────

# Supabase (obrigatórias) — projeto e chave anônima (pública, protegida por RLS).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Multi-tenant / roteamento por subdomínio (opcionais em dev).
# Domínio raiz da plataforma (ex.: kora.codes). Sem ele, roda em domínio nu.
VITE_ROOT_DOMAIN=
# Slug do tenant quando não há subdomínio (dev/preview). Fallback: gastromundi.
VITE_TENANT_SLUG_FALLBACK=
# Força um slug de tenant específico (dev). Deixe vazio em produção.
VITE_TENANT_SLUG=
# Subdomínio do console da plataforma (ex.: console). Opcional.
VITE_CONSOLE_SUBDOMAIN=
# Simula a landing do apex em dev (true/false). Opcional.
VITE_APEX_PREVIEW=
# URL de contato exibida na landing do apex (ex.: link de WhatsApp comercial).
# NUNCA colocar número pessoal aqui.
VITE_CONTATO_URL=

# Observabilidade — Sentry (Fase 1). Opcionais: sem VITE_SENTRY_DSN o app
# roda idêntico (fail-open) e nada é enviado. Só inicializa em produção.
# O DSN é público por design — a proteção real é o scrub (LGPD).
VITE_SENTRY_DSN=
# Versão/release para amarrar o erro à build. Na Vercel, usar o hash do commit.
VITE_APP_VERSION=

# ── Segredos SÓ do build (server-side na Vercel — NÃO levam prefixo VITE_,
#    NÃO vão pro bundle). Usados pelo @sentry/vite-plugin para subir os
#    source maps. Sem eles, o build roda sem upload de source map.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
